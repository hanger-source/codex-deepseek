--- /dev/null
+++ b/internal/translator/claude/openai/responses/deepseek_cases_test.go
@@ -0,0 +1,135 @@
+package responses
+
+import (
+	"encoding/json"
+	"os"
+	"path/filepath"
+	"strings"
+	"testing"
+
+	"github.com/tidwall/gjson"
+)
+
+type testCase struct {
+	Name  string            `json:"name"`
+	Input []json.RawMessage `json:"input"`
+}
+
+func TestDeepSeekCases(t *testing.T) {
+	casesDir := "/Users/hanger/third-party/CLIProxyAPI/test/deepseek/cases"
+	files, err := filepath.Glob(filepath.Join(casesDir, "*.json"))
+	if err != nil || len(files) == 0 {
+		t.Fatalf("no test cases found in %s", casesDir)
+	}
+
+	for _, f := range files {
+		data, err := os.ReadFile(f)
+		if err != nil {
+			t.Fatalf("read %s: %v", f, err)
+		}
+		var tc testCase
+		if err := json.Unmarshal(data, &tc); err != nil {
+			t.Fatalf("parse %s: %v", f, err)
+		}
+
+		t.Run(tc.Name, func(t *testing.T) {
+			// Build full request JSON
+			inputJSON, _ := json.Marshal(tc.Input)
+			reqJSON := []byte(`{"model":"test","input":` + string(inputJSON) + `}`)
+
+			out := ConvertOpenAIResponsesRequestToClaude("test-model", reqJSON, false)
+			msgs := gjson.GetBytes(out, "messages")
+			if !msgs.IsArray() {
+				t.Fatal("messages is not array")
+			}
+
+			arr := msgs.Array()
+			var prevRole string
+
+			for i, m := range arr {
+				role := m.Get("role").String()
+				content := m.Get("content")
+
+				// Rule 1: no consecutive assistant
+				if role == "assistant" && prevRole == "assistant" {
+					t.Errorf("[%d] consecutive assistant messages", i)
+				}
+
+				if role == "assistant" {
+					if !content.IsArray() {
+						t.Errorf("[%d] assistant content not array", i)
+						prevRole = role
+						continue
+					}
+					cArr := content.Array()
+
+					// Rule 2: exactly one thinking block at position 0
+					thinkCount := 0
+					for j, c := range cArr {
+						if c.Get("type").String() == "thinking" {
+							thinkCount++
+							if j != 0 {
+								t.Errorf("[%d] thinking at position %d, want 0", i, j)
+							}
+						}
+					}
+					if thinkCount != 1 {
+						t.Errorf("[%d] thinking count=%d, want 1", i, thinkCount)
+					}
+
+					// Rule 3: tool_use followed by user(tool_result)
+					var tuIDs []string
+					for _, c := range cArr {
+						if c.Get("type").String() == "tool_use" {
+							tuIDs = append(tuIDs, c.Get("id").String())
+						}
+					}
+					if len(tuIDs) > 0 && i+1 < len(arr) {
+						next := arr[i+1]
+						if next.Get("role").String() != "user" {
+							t.Errorf("[%d] tool_use followed by %s, want user", i, next.Get("role").String())
+						} else if next.Get("content").IsArray() {
+							var trIDs []string
+							next.Get("content").ForEach(func(_, c gjson.Result) bool {
+								if c.Get("type").String() == "tool_result" {
+									trIDs = append(trIDs, c.Get("tool_use_id").String())
+								}
+								return true
+							})
+							for _, id := range tuIDs {
+								found := false
+								for _, tr := range trIDs {
+									if tr == id {
+										found = true
+										break
+									}
+								}
+								if !found {
+									t.Errorf("[%d] tool_use id=%s has no matching tool_result", i, id)
+								}
+							}
+						}
+					}
+				}
+				prevRole = role
+			}
+
+			// Rule 4: no assistant text lost
+			for _, item := range tc.Input {
+				var parsed map[string]interface{}
+				json.Unmarshal(item, &parsed)
+				if parsed["type"] == "message" && parsed["role"] == "assistant" {
+					if content, ok := parsed["content"].([]interface{}); ok && len(content) > 0 {
+						if first, ok := content[0].(map[string]interface{}); ok {
+							if text, ok := first["text"].(string); ok && text != "" {
+								if !strings.Contains(string(out), text) {
+									t.Errorf("assistant text %q lost in translation", text)
+								}
+							}
+						}
+					}
+				}
+			}
+		})
+	}
+}
